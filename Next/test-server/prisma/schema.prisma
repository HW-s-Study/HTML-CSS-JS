generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Author {
  id          Int      @id @default(autoincrement())
  name_kr     String
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  books       Book[]

  @@map("authors")
}

model Book {
  id           Int      @id @default(autoincrement())
  title_kr     String
  title        String
  author_id    Int
  isbn         String
  publisher    String
  published_at DateTime
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  author       Author   @relation(fields: [author_id], references: [id])

  @@map("books")
}
